{
  "name": "robocopy-gui",
  "private": true,
  "version": "0.1.0",
  "description": "Modern Robocopy GUI for Windows with drag-drop, presets, and live logs.",
  "author": "Aryan",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && set VITE_DEV_SERVER_URL=http://localhost:5173&& electron .\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder -w portable nsis",
    "dist:portable": "npm run build && electron-builder -w portable",
    "dist:installer": "npm run build && electron-builder -w nsis",
    "preview": "vite preview"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xxhash-wasm": "^1.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.robocopy.pro",
    "productName": "RoboCopy Pro",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "node_modules/xxhash-wasm/**",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "RoboCopy-Pro-Portable-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh",
      "artifactName": "RoboCopy-Pro-Setup-${version}.${ext}"
    }
  }
}
